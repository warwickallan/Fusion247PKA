# fusion-capture-gateway — environment variable NAMES only.
#
# WP0 fixtures-only baseline. This file carries KEY NAMES with EMPTY values.
# NEVER put real values here. Real secrets are injected into the environment
# (secret manager / OS-keychain-backed .env kept OUTSIDE the repo tree) and ONLY
# AFTER the Vex WP0 security gate passes (Security/wp0-security-gate.md §6).
#
# The real .env is gitignored. This .env.example is the only env file committed.

# Supabase operational store (server-side worker + intake only).
SUPABASE_URL=
# SECRET — service_role key. Worker/server side ONLY, never a client surface.
SUPABASE_SERVICE_ROLE_KEY=

# SECRET — Telegram bot token. Treated as a full account credential; masked in
# every log; a dev/throwaway bot until the gate passes (never the real bot).
TELEGRAM_BOT_TOKEN=

# The local worker's identity/principal (least-privilege).
WORKER_ID=

# Single authorised Telegram numeric user id (allowlist of one). A NUMERIC id,
# never a username. A test id until the gate passes — never Warwick's real id.
AUTHORISED_TELEGRAM_USER_ID=

# Sandbox directory the governed Markdown write lands in (fixtures). A throwaway
# local path; NOT the canonical Brain until the gate passes.
CAPTURE_SANDBOX_DIR=
