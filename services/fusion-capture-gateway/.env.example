# fusion-capture-gateway — environment variable NAMES only.
#
# This file carries KEY NAMES with EMPTY values. NEVER put real values here.
# Real secrets are injected into the runtime environment's secret store (see
# README "Where each secret goes") and ONLY AFTER the Vex WP0 credential-boundary
# review passes. The real .env is gitignored; this .env.example is the only env
# file committed.
#
# CREDENTIAL MODEL (PREPROVISION-CORRECTION-0001 §1) — three DISTINCT surfaces:
#   A. Build-time project access → Supabase MCP (Warwick browser OAuth). NOT here.
#   B. Database runtime access    → DATABASE_URL below (the ONLY runtime secret).
#   C. Supabase Data API keys     → optional/reserved; unused by WP0. NOT required.

# ============================================================================
# REQUIRED for the WP0 long-poll live proof
# ============================================================================

# SECRET — (B) Postgres connection string from the Supabase "Connect" screen,
# SESSION POOLER host (aws-<n>-<region>.pooler.supabase.com:5432, user
# postgres.<project-ref>). Carries the PROJECT DATABASE PASSWORD, NOT a
# service_role API key.
#
# TLS (FU-1, Vex-mandated): verify-full with the PINNED pooler CA. Preferred:
# keep the DSN free of ssl params and set DATABASE_SSL_CA_FILE below. DSN-only
# alternative: append ?sslmode=verify-full&sslrootcert=<path to the CA .pem>.
# NEVER a bare require-mode sslmode — node-postgres does NOT verify the CA for
# it (silently weaker than libpq; see SECURITY.md §2).
# Example (placeholders — never commit a real one):
#   postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=

# FU-1 — path to the pinned Supabase pooler CA certificate (PUBLIC cert, not a
# secret). The committed copy lives at
#   services/fusion-capture-gateway/certs/supabase-pooler-ca.pem
# When set, the worker connects verify-full with an explicit ssl config object
# (rejectUnauthorized: true + this CA) and strips any ssl params from the DSN
# so the pinned CA can never be silently replaced (node-postgres trap).
DATABASE_SSL_CA_FILE=

# SECRET — Telegram bot token from @BotFather. A full bot account credential;
# masked in every log. A throwaway DEV bot until the gate passes.
TELEGRAM_BOT_TOKEN=

# Single authorised Telegram NUMERIC user id (allowlist of one). A NUMERIC id
# (from @userinfobot), never a username. Not a secret.
AUTHORISED_TELEGRAM_USER_ID=

# The local worker's identity/principal (least-privilege label). Not a secret.
WORKER_ID=

# ============================================================================
# OPTIONAL for WP0
# ============================================================================

# Governed capture destination for the LIVE writer. When UNSET in live mode the
# runtime resolves the authority-backed governed inbox (repo `Team Inbox/`, per
# root AGENTS.md + Team Inbox/README.md), landing notes under Team Inbox/captures/.
# Set only to override that governed default with an explicit path. Not a secret.
CAPTURE_BRAIN_DIR=

# ============================================================================
# RESERVED / FUTURE — do NOT provision for WP0
# ============================================================================
# (C) Supabase Data API. The WP0 runtime reaches Postgres over DATABASE_URL and
# does NOT call the REST/Data API, so these are NOT required and NOT requested.
# If a future WP needs Data API access, prefer Supabase's current
# publishable/secret key model over legacy anon/service_role, and document it.
SUPABASE_URL=
# SECRET — modern Supabase secret key (server-side). Optional/reserved.
SUPABASE_SECRET_KEY=

# SECRET — Telegram webhook authenticity token (F-10). In WP1 the webhook
# transport is served by the Supabase Edge Function (fcg-webhook-intake), whose
# copy of this secret is provisioned via `supabase secrets set` — NOT here. The
# LOCAL worker keeps long-polling and does NOT need it; leave empty unless a
# local webhook receiver ever exists. Masked if ever set.
TELEGRAM_WEBHOOK_SECRET=
