# fusion-tower — environment variable NAMES only.
#
# This file carries KEY NAMES with EMPTY values. NEVER put real values here.
# The real .env is gitignored; this .env.example is the only env file committed.
# Absent GATED credentials do NOT crash the Tower — the relevant adapter runs
# fail-closed in record-blocker mode. Absent DATABASE_URL => whole Tower runs in
# fixtures mode against the in-memory store.

# ============================================================================
# CORE runtime
# ============================================================================

# SECRET — libpq connection string to the SAME Supabase project as BUILD-002 but
# the `ftw` schema. Carries the Postgres role password inline. TLS required for
# real Supabase (append ?sslmode=require or rely on DATABASE_SSL_CA_FILE).
#   postgresql://postgres:<db-password>@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL=

# PATH (not a secret) — pinned CA PEM for verify-full TLS to the Supabase pooler.
DATABASE_SSL_CA_FILE=

# Dispatcher principal label (not a secret).
TOWER_ID=

# 'owner/repo' the Tower governs — read scope for GitHub polling (not a secret).
GITHUB_REPO=

# ============================================================================
# GATED adapter credentials — absent => that adapter is fail-closed (blocker),
# NOT a crash. Provision only after the relevant Warwick gate is cleared.
# ============================================================================

# SECRET — OpenAI/Codex controller (gpt_codex). Either name is accepted.
CODEX_API_KEY=
OPENAI_API_KEY=

# SECRET — optional for the Larry (claude) headless adapter in --bare mode. When
# absent, the adapter uses the machine's ambient claude auth if available.
ANTHROPIC_API_KEY=

# SECRET — GitHub REST (authenticated read + gated write). Public-repo read works
# unauthenticated for the WP0 proof.
GITHUB_TOKEN=

# SECRET — ClickUp REST (gated).
CLICKUP_TOKEN=

# SECRET — Telegram control-channel bot token. WP0 must NOT reuse BUILD-002's bot
# token for a second long-poll (409 conflict). A dedicated Tower bot or a
# shared-router decision is a Warwick gate.
TELEGRAM_BOT_TOKEN=

# Single authorised Telegram NUMERIC user id (allowlist of one). Not a secret.
AUTHORISED_TELEGRAM_USER_ID=

# ============================================================================
# HMAC signing secrets (per honest principal). SECRET. >=32-byte CSPRNG values.
# agent_identity.signing_key_ref stores the NAME (pointer), never the value.
# ============================================================================
TOWER_HMAC_SECRET_LARRY=
TOWER_HMAC_SECRET_GPT_CODEX=
TOWER_HMAC_SECRET_TOWER=
