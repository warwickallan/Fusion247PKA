# WP-D disposable Directus cockpit — .env TEMPLATE (masked).
# The REAL .env is generated by setup-directus.mjs from .runtime/runtime.json and is
# gitignored. NEVER commit real values. Everything here is LOCAL-ONLY / DEV-ONLY.
HOST=127.0.0.1
PORT=8074
PUBLIC_URL=http://127.0.0.1:8074
KEY=<generated-uuid>
SECRET=<generated-hex>
DB_CLIENT=pg
DB_HOST=127.0.0.1
DB_PORT=<provisioned-cluster-port>
DB_DATABASE=controlplane
DB_USER=cp_admin
DB_PASSWORD=<dev-only-local-password>
ADMIN_EMAIL=admin@wpd.example.com
ADMIN_PASSWORD=<generated-masked>
TELEMETRY=false
WEBSOCKETS_ENABLED=false
CACHE_ENABLED=false
LOG_LEVEL=warn
